# Agent Template Kits local defaults.
# Copy to .env for local overrides. Do not put real secrets in this file.

# === Tool Runtime ===
PYTHON=python3

# === Optional Tool Overrides ===
# Leave empty to let prompt-cache scripts use their bundled assets.
PROMPT_CACHE_ASSET_DIR=

# Optional profile-contract locations for standalone installer copies.
PROMPT_CACHE_PROFILE_ROOT=
WORKFLOW_PROFILE_ROOT=
